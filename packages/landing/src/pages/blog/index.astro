---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog — Spool</title>
  <meta name="description" content="Updates, technical deep-dives, and product announcements from the Spool team.">

  <meta property="og:title" content="Blog — Spool">
  <meta property="og:description" content="Updates, technical deep-dives, and product announcements from the Spool team.">
  <meta property="og:image" content="https://spool.pro/og-image.png">

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #FAFAF8;
      --surface: #F4F4F0;
      --surface2: #EEEEE9;
      --border: #E8E8E2;
      --border2: #D8D8D0;
      --text: #1C1C18;
      --muted: #6B6B60;
      --faint: #ADADAA;
      --accent: #C85A00;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #141410;
        --surface: #1C1C18;
        --surface2: #242420;
        --border: #2E2E28;
        --border2: #3A3A34;
        --text: #F2F2EC;
        --muted: #8A8A80;
        --faint: #505048;
        --accent: #F07020;
      }
    }

    html {
      font-family: 'Geist', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    body { min-height: 100vh; }

    nav {
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.04em;
      text-decoration: none;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-logo svg { width: 22px; height: 22px; color: var(--accent); }
    .nav-logo .dot { color: var(--accent); margin-left: -4px; }

    .nav-links { display: flex; align-items: center; gap: 24px; }
    .nav-links a { font-size: 13px; font-weight: 500; color: var(--muted); text-decoration: none; transition: color 80ms; }
    .nav-links a:hover { color: var(--text); }

    .page-header {
      max-width: 720px;
      margin: 80px auto 48px;
      padding: 0 24px;
    }

    .page-header h1 {
      font-size: clamp(28px, 4vw, 40px);
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 8px;
    }

    .page-header p {
      color: var(--muted);
      font-size: 16px;
    }

    .posts {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 24px 120px;
    }

    .post-card {
      display: block;
      padding: 24px 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      color: inherit;
      transition: opacity 80ms;
    }

    .post-card:first-child {
      border-top: 1px solid var(--border);
    }

    .post-card:hover { opacity: 0.8; }

    .post-card h2 {
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 6px;
    }

    .post-card p {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 8px;
    }

    .post-meta {
      font-size: 12px;
      color: var(--faint);
      display: flex;
      gap: 12px;
    }

    .post-tags {
      display: flex;
      gap: 4px;
    }

    .tag {
      padding: 1px 8px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 9999px;
      font-size: 11px;
      color: var(--muted);
    }

    .empty {
      text-align: center;
      padding: 64px 24px;
      color: var(--muted);
      font-size: 15px;
    }

    footer {
      padding: 32px;
      text-align: center;
      border-top: 1px solid var(--border);
      font-size: 12px;
      color: var(--faint);
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--text); }

    @media (max-width: 768px) {
      nav { padding: 12px 16px; }
      .page-header { margin-top: 48px; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor">
        <ellipse cx="16" cy="9" rx="12" ry="4.5" stroke-width="1.8"/>
        <line x1="4" y1="9" x2="4" y2="22" stroke-width="1.8"/>
        <line x1="28" y1="9" x2="28" y2="22" stroke-width="1.8"/>
        <path d="M4 22 C4 24.5 9 27 16 27 C23 27 28 24.5 28 22" stroke-width="1.8"/>
        <ellipse cx="16" cy="11" rx="7" ry="2.5" stroke-width="1.2"/>
        <line x1="9" y1="11" x2="9" y2="20" stroke-width="1.2"/>
        <line x1="23" y1="11" x2="23" y2="20" stroke-width="1.2"/>
        <path d="M9 20 C9 21.5 12 23 16 23 C20 23 23 21.5 23 20" stroke-width="1.2"/>
        <ellipse cx="16" cy="11" rx="3" ry="1.2" fill="currentColor" stroke="none"/>
      </svg>
    Spool<span class="dot">.</span></a>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/docs/">Docs</a>
      <a href="/blog/">Blog</a>
      <a href="https://github.com/spool-lab/spool">GitHub</a>
    </div>
  </nav>

  <header class="page-header">
    <h1>Blog</h1>
    <p>Updates, technical deep-dives, and product announcements.</p>
  </header>

  <main class="posts">
    {posts.length === 0 && (
      <div class="empty">No posts yet. Check back soon.</div>
    )}
    {posts.map(post => (
      <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="post-card">
        <h2>{post.data.title}</h2>
        <p>{post.data.description}</p>
        <div class="post-meta">
          <span>{post.data.author}</span>
          <span>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          {post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </a>
    ))}
  </main>

  <footer>
    <p>Spool by <a href="https://github.com/doodlewind">Yifeng</a></p>
  </footer>
</body>
</html>

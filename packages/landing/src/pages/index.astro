<script>
  // --- theme toggle ---
  const themeBtn = document.getElementById('themeBtn');
  themeBtn.addEventListener('click', () => {
    const html = document.documentElement;
    const cur = html.getAttribute('data-theme');
    if (cur === 'dark') {
      html.setAttribute('data-theme', 'light');
    } else if (cur === 'light') {
      html.removeAttribute('data-theme');
    } else {
      // currently following system; toggle to opposite of system
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      html.setAttribute('data-theme', prefersDark ? 'light' : 'dark');
    }
  });

  // --- install copy ---
  function copyInstall(el) {
    const cmd = el.querySelector('code').textContent;
    navigator.clipboard.writeText(cmd).then(() => {
      el.classList.add('copied');
      const ic = el.querySelector('.copy');
      const prev = ic.innerHTML;
      ic.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      setTimeout(() => { el.classList.remove('copied'); ic.innerHTML = prev; }, 1600);
    });
  }
  window.copyInstall = copyInstall;

  // --- hero typed search ---
  const phrases = [
    'refresh token rotation',
    'how did we fix the 3am cookie bug',
    'local-first sync approaches',
    'what did I ship last week',
    'build on last month\u2019s caching talk'
  ];
  const typedEl = document.getElementById('heroTyped');
  let pi = 0, ci = 0, del = false, pause = 0;
  function type() {
    const p = phrases[pi];
    if (pause > 0) { pause--; setTimeout(type, 28); return; }
    if (!del) {
      typedEl.textContent = p.substring(0, ci + 1);
      ci++;
      if (ci === p.length) { del = true; pause = 70; }
    } else {
      typedEl.textContent = p.substring(0, ci - 1);
      ci--;
      if (ci === 0) { del = false; pi = (pi + 1) % phrases.length; pause = 12; }
    }
    setTimeout(type, del ? 22 : 55 + Math.random() * 40);
  }
  type();

  // --- ticker ---
  const tickerItems = [
    { name: 'Claude Code', color: 'var(--src-claude)', count: '342' },
    { name: 'Codex CLI', color: 'var(--src-codex)', count: '57' },
    { name: 'Gemini CLI', color: 'var(--src-gemini)', count: '41' },
    { name: 'ChatGPT', color: 'var(--src-chatgpt)', count: '128' },
    { name: 'GitHub Stars', color: 'var(--src-github)', count: '1.2k' },
    { name: 'Twitter / X', color: 'var(--src-twitter)', count: '891' },
    { name: 'YouTube', color: 'var(--src-youtube)', count: '64' },
    { name: 'Reddit', color: '#FF4500', count: '203' },
    { name: 'Substack', color: '#FF6719', count: '48' },
    { name: 'LinkedIn', color: '#0A66C2', count: '19' },
    { name: 'Hypothesis', color: '#BD1C2B', count: '112' },
    { name: 'Readwise', color: '#888', count: '380' },
  ];
  function tickerMarkup(items) {
    return items.map(i => `
      <span class="ticker-item">
        <span class="ico"><span style="width:8px;height:8px;border-radius:50%;background:${i.color};display:inline-block;"></span></span>
        ${i.name}
        <span class="count">${i.count}</span>
      </span>
    `).join('');
  }
  const ticker = document.getElementById('ticker');
  ticker.innerHTML = tickerMarkup(tickerItems) + tickerMarkup(tickerItems);
</script>


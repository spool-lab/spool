{
  "name": "@spool-lab/cli",
  "version": "0.3.8",
  "private": false,
  "type": "module",
  "bin": {
    "spool": "./bin/spool.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x bin/spool.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@spool-lab/core": "workspace:^",
    "commander": "^13.1.0",
    "undici": "^6.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "better-sqlite3": "^12.9.0",
    "vitest": "^3.2.4"
  }
}

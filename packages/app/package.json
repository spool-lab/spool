{
  "name": "@spool/app",
  "version": "0.3.3",
  "private": true,
  "productName": "Spool",
  "main": "./out/main/index.js",
  "scripts": {
    "rebuild:native": "pnpm run rebuild:native:electron",
    "rebuild:native:electron": "electron-rebuild -f -w better-sqlite3",
    "build:core": "pnpm --filter @spool/core build",
    "dev": "pnpm run build:core && pnpm run rebuild:native && electron-vite dev",
    "build": "pnpm run build:core && electron-vite build && electron-builder --publish never",
    "build:mac": "pnpm run build:core && electron-vite build && electron-builder --mac --arm64",
    "build:linux": "pnpm run build:core && electron-vite build && electron-builder --linux",
    "build:electron": "pnpm run build:core && electron-vite build",
    "preview": "electron-vite preview",
    "clean": "rm -rf out dist-electron",
    "test:e2e": "pnpm run build:core && pnpm run rebuild:native:electron && npx playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@shipany/open-agent-sdk": "link:/Users/claw/code/linkclaw/open-agent-sdk",
    "@spool/core": "workspace:*",
    "@tanstack/react-virtual": "^3.13.6",
    "acp-extension-claude": "^0.21.0",
    "acp-extension-codex": "^0.10.0",
    "better-sqlite3": "^11.10.0",
    "bindings": "^1.5.0",
    "electron-updater": "^6.8.3",
    "file-uri-to-path": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.3"
  },
  "build": {
    "appId": "com.linkclaw.spool",
    "productName": "Spool",
    "publish": [
      {
        "provider": "github",
        "owner": "spool-lab",
        "repo": "spool"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/acp-extension-claude/**",
      "node_modules/acp-extension-codex/**",
      "node_modules/acp-extension-codex-darwin-arm64/**",
      "node_modules/acp-extension-codex-linux-x64/**",
      "node_modules/acp-extension-core/**",
      "node_modules/@agentclientprotocol/**",
      "node_modules/@anthropic-ai/claude-agent-sdk/**",
      "node_modules/@shipany/open-agent-sdk/**",
      "node_modules/zod/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Development",
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "AppImage"
        }
      ]
    },
    "dmg": {
      "title": "Spool",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "optionalDependencies": {
    "acp-extension-codex-darwin-arm64": "^0.10.0",
    "acp-extension-codex-linux-x64": "^0.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^34.5.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.3"
  }
}

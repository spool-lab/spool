{
  "name": "@spool/share-kit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles/global.css",
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/fonts.css": "./src/styles/fonts.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "pnpm run clean && vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "idb-keyval": "^6.2.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.460.0 || ^1.0.0",
    "react-markdown": "^9.0.0 || ^10.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^0.460.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "^6.3.3",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4"
  }
}

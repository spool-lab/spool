# Dependencies
node_modules/

# Build outputs
dist/
out/
packages/*/dist/
packages/*/out/
packages/app/out/

# Electron build
dist-electron/

# Turbo cache
.turbo/

# Astro
.astro/

# Void
.void/
.wrangler/

# Source maps
*.js.map
*.d.ts.map

# OS
.DS_Store

# Local env
.env
.env.local

# Spool DB (user data, not committed)
.spool/

# Browse tool session state
.gstack/

# Git worktrees
.worktrees/
.claude/worktrees/

# Native binaries (rebuilt per-platform via electron-rebuild)
build/
!packages/app/build/
*.node

# Compiled artifacts that may end up in src/ by mistake
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
# Playwright
test-results/
playwright-report/
.playwright-mcp/

# Superpowers (agent-generated plans/specs)
.superpowers/
docs/superpowers/

# Demo capture artifacts (rebuilt per release video; not source)
packages/app/artifacts/

# Release video build outputs (per-release; never committed)
# Source of truth is index.html + scripts. Assets (clips, audio, logos) are
# regenerated/sourced per release, not stored in git.
videos/*/assets/
videos/*/renders/
videos/*/.hyperframes/
videos/*/node_modules/
